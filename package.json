{
  "name": "noctra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:all": "concurrently --names next,express --prefix-colors cyan,yellow \"pnpm run dev\" \"pnpm run server:dev\"",
    "server:dev": "tsx watch src/server/index.ts",
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.2",
    "@base-ui/react": "^1.5.0",
    "@corsair-dev/cli": "^0.1.19",
    "@corsair-dev/gmail": "^0.1.4",
    "@corsair-dev/googlecalendar": "^0.1.3",
    "@corsair-dev/mcp": "^0.1.22",
    "@openai/agents": "^0.11.6",
    "@phosphor-icons/react": "^2.1.10",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "better-auth": "^1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "corsair": "^0.1.76",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.41.0",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "next": "^15.2.3",
    "ngrok": "5.0.0-beta.2",
    "openai": "^6.42.0",
    "postgres": "^3.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.30.5",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "eslint-plugin-drizzle": "^0.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.7.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@10.33.0"
}
